# Real backend base URL. Ignored while VITE_USE_MOCK=true.
# Use this when running apps/api locally on port 3000.
VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=/api/v1

# true = AuthContext talks to the in-memory mock in src/lib/mockData.ts instead of the real API.
# Flip to false once apps/api is running and reachable at VITE_API_URL.
VITE_USE_MOCK=true
